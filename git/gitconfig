# many things from jessfraz/dotfiles/.gitconfig

[alias]
# View abbreviated SHA, description, and history graph of the latest 20 commits
l = log --pretty=oneline -n 20 --graph --abbrev-commit

# View history graph of the all commits
lg = log --color --decorate --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an (%G?)>%Creset' --abbrev-commit

# View the current working tree status using the short format
s = status -s

# Show the diff between the latest commit and the current state
d = !"git diff-index --quiet HEAD -- || clear; git --no-pager diff --patch-with-stat"

# Show diff of staged files
dc = diff --cached

# Switch to a branch, creating it if necessary
go = "!f() { git checkout \"$1\" 2> /dev/null || git checkout -b \"$1\"; }; f"

# Create pull request
pr = pull-request

branches = branch -a
remotes = remote -v
tags = tag -l

# from trevor bramble https://twitter.com/TrevorBramble/status/774292970681937920
aliases=!git config -l | grep ^alias | cut -c 7- | sort

# Remove branches that have already been merged with master
# a.k.a. ‘delete merged’
dm = "!git branch --merged | grep -v '\\*' | xargs -n 1 git branch -d; git remote -v update -p"

# from seth vargo https://gist.github.com/sethvargo/6b2f7b592853381690bfe3bd00947e8f
undo = !git reset HEAD~1 --mixed
amend = !git commit --amend

# gitignore.io
ignore = "!gi() { curl -L -s https://www.gitignore.io/api/$@ ;}; gi"

[core]
# Use custom `.gitignore` and `.gitattributes`
excludesfile = ~/.gitignore
attributesfile = ~/.gitattributes

# Treat spaces before tabs and all kinds of trailing whitespace as an error
# [default] trailing-space: looks for spaces at the end of a line
# [default] space-before-tab: looks for spaces before tabs at the beginning of a line
whitespace = space-before-tab,-indent-with-non-tab,trailing-space

# Make `git rebase` safer on OS X
# More info: <http://www.git-tower.com/blog/make-git-rebase-safe-on-osx/>
trustctime = false
editor = vim

[diff]
# Detect copies as well as renames
renames = copies
tool = Kaleidoscope

[difftool]
prompt = false

[difftool "Kaleidoscope"]
cmd = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"

[merge]
tool = Kaleidoscope

[mergetool]
prompt = false

[mergetool "Kaleidoscope"]
cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" \"$REMOTE\"

[pull]
# pull --rebase
rebase = true

[help]
# Automatically correct and execute mistyped commands
autocorrect = 1

[url "git@github.com:"]
insteadOf = https://github.com/
insteadOf = "github:"
insteadOf = "git://github.com/"

[commit]
gpgsign = true
