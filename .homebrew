#!/bin/sh

ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"

brew tap caskroom/cask

# Install the latest versions of git, node, python 2 & 3 and go
brew install git node python python3 go

# Install macvim
brew install macvim

# Install applicaitons
brew cask install iterm2 1password caffeine spectacle tower alfred flux kaleidoscope spotify atom dropbox google-chrome slack
