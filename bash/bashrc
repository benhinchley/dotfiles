#!/usr/bin/env bash

# bash completion
if [ -f /usr/local/etc/bash_completion ]; then source /usr/local/etc/bash_completion; fi

# PS1
export GIT_PS1_SHOWDIRTYSTATE=true
export GIT_PS1_SHOWUNTRACKEDFILES=true
export PS1="\\A \\W\$(__git_ps1 ':[%s]')\\n$ "

# aliases
alias l="ls -lF"
alias la="ls -laF"
alias ls="command ls"
alias mkdir="mkdir -p"
alias ping="ping -c 10"
alias git="hub"
alias g="git"
alias m="make"

# functions
csv() { sed -e 's/,,/, ,/g' | column -s, -t | less -\#5 -N -S ;}

goinstall() {
	if [[ $# -ne 1 ]]; then
		echo "version number needed"
		return 1
	fi

	local VERSION="$1"

	if [ ! -f "$HOME/Downloads/go$VERSION.tar.gz" ]; then
		echo "downloading go $VERSION"
		curl -o "$HOME/Downloads/go$VERSION.tar.gz" -sL \
			"https://dl.google.com/go/go$VERSION.darwin-amd64.tar.gz"
	fi

	echo "removing go $(go version | sed 's/go version go//')"
	sudo rm -rf /usr/local/go

	echo "installing go $VERSION darwin/amd64"
	sudo tar -C /usr/local -xzf "$HOME/Downloads/go$VERSION.tar.gz"
}

# Larger bash history (allow 32³ entries; default is 500)
export HISTSIZE=50000000;
export HISTFILESIZE=$HISTSIZE;
export HISTCONTROL=ignoredups;
# Make some commands not show up in history
export HISTIGNORE=" *:ls:cd:cd -:pwd:exit:date:* --help:* -h:pony:pony add *:pony update *:pony save *:pony ls:pony ls *:clear:&";

# GPG
GPG_TTY=$(tty)
export GPG_TTY

# gcloud
if [ -f "${HOME}/google-cloud-sdk/path.bash.inc" ]; then source "${HOME}/google-cloud-sdk/path.bash.inc"; fi
if [ -f "${HOME}/google-cloud-sdk/completion.bash.inc" ]; then source "${HOME}/google-cloud-sdk/completion.bash.inc"; fi
if which dev_appserver.py > /dev/null; then
    alias devappserver="dev_appserver.py"
fi

# fzf
[ -f ~/.fzf.bash ] && source ~/.fzf.bash
export FZF_DEFAULT_OPTS="--no-mouse --ansi --cycle"

# python
export PATH="/usr/local/opt/python/libexec/bin:$PATH"

# go
export GOPATH="$HOME/.go/thirdparty:$HOME/.go/projects"
export PATH="$HOME/.go/thirdparty/bin:$HOME/.go/projects/bin:$PATH:/usr/local/go/bin"
export CDPATH=${CDPATH}:$HOME/.go/projects/src/github.com:$HOME/.go/projects/src

# repositories
export CDPATH=${CDPATH}:$HOME/.code/github.com

# coreutils
export PATH="/usr/local/opt/coreutils/libexec/gnubin:$PATH"
export MANPATH="/usr/local/opt/coreutils/libexec/gnuman:$MANPATH"

# direnv
eval "$(direnv hook bash)"
